{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run Test Runner Container",
            "type": "shell",
            "command": "docker-compose",
            "args": ["-f", "docker-compose.test.yaml", "up", "-d", "test_runner"],
            "problemMatcher": []
        },
        {
            "label": "Stop Test Runner Container",
            "type": "shell",
            "command": "docker-compose",
            "args": ["-f", "docker-compose.test.yaml", "down"],
            "problemMatcher": []
        },
        {
            "label": "Start Test Runner with Target File",
            "type": "shell",
            "command": "basename ${file} .py > test_target.txt && docker-compose -f docker-compose.test.yaml up -d test_runner",
            "problemMatcher": []
        }
    ]
}