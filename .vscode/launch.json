{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Attach to Test Runner in Docker",
            "type": "debugpy",
            "request": "attach",
            "connect": {
                "host": "localhost",
                "port": 5678
            },
            "pathMappings": [
                {
                    "localRoot": "${workspaceFolder}",
                    "remoteRoot": "/app"
                }
            ],
            "justMyCode": true,
            "preLaunchTask": "Start Test Runner with Target File",
            "postDebugTask": "Stop Test Runner Container"
        }
    ]
}