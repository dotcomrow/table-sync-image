# Table Sync Configuration
DATABASE_URL=postgresql://yugabyte:yugabyte@localhost:5433/yugabyte
BIGQUERY_PROJECT_ID=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
DEBEZIUM_CONNECTOR_URL=http://localhost:8083
SCAN_INTERVAL_SECONDS=30
LOG_LEVEL=INFO

# Debezium Configuration
DEBEZIUM_DATABASE_HOSTNAME=yugabyte-host
DEBEZIUM_DATABASE_PORT=5433
DEBEZIUM_DATABASE_USER=yugabyte
DEBEZIUM_DATABASE_PASSWORD=yugabyte
DEBEZIUM_DATABASE_NAME=yugabyte

# BigQuery Configuration
BIGQUERY_LOCATION=US
BIGQUERY_DATASET_LOCATION=US

# Data Transfer Configuration
TEMP_STORAGE_BUCKET=your-temp-storage-bucket
MAX_PARALLEL_TRANSFERS=3
BATCH_SIZE=10000